# ============================================================
# 再塑通 RePlasMatch — 微信云托管环境变量
# 复制此文件内容到云托管控制台的环境变量配置中
# ============================================================

# ---- 运行模式 ----
NODE_ENV=production
DB_TYPE=mysql
STORAGE_TYPE=cos
PORT=3456

# ---- MySQL 数据库 (TDSQL-C) ----
# 云托管控制台 → 数据库 → 查看连接信息
MYSQL_HOST=your-db-instance.mysql.tencentcdb.com
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your_password_here
MYSQL_DATABASE=zaisutong

# ---- JWT 认证 ----
# 生成密钥: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change_me_to_random_64_hex
JWT_EXPIRES_IN=15m
REFRESH_SECRET=change_me_to_random_64_hex

# ---- CORS / WebSocket ----
ALLOWED_ORIGIN=*
WS_ALLOWED_ORIGINS=*

# ---- 微信小程序 ----
WX_APPID=wxa2faf03e11d14fed
WX_APPSECRET=your_appsecret_here

# ---- AI 识别 (DeepSeek，可选) ----
DEEPSEEK_API_KEY=
DEEPSEEK_API_BASE=https://api.deepseek.com

# ---- 邮件服务 (SMTP) ----
SMTP_HOST=smtp.qq.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=your_email@qq.com
SMTP_PASS=your_smtp_auth_code
SMTP_FROM=再塑通 <your_email@qq.com>

# ---- COS 存储 (云托管自动注入，无需手动配置) ----
# COS_BUCKET   — 云托管自动注入
# COS_REGION   — 云托管自动注入
# TCB_ENV      — 云托管自动注入
