# ============================================================
# 再塑通 RePlasMatch — 生产环境配置
# 部署时复制为 backend/.env，替换所有占位符
# ============================================================

# 服务端口（Nginx 反向代理到此端口）
PORT=3456

# JWT 密钥 —— 必须更换为随机字符串！
# 生成方式：node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=请替换为64字节随机hex字符串

# JWT Token 有效期
JWT_EXPIRES_IN=7d

# 数据库路径
DB_PATH=./data/zaisutong.db

# CORS —— 生产环境必须指定实际域名
ALLOWED_ORIGIN=https://api.zaisutong.cn

# 速率限制：每窗口最大请求数（生产环境建议收紧）
RATE_LIMIT_MAX=200
RATE_LIMIT_WINDOW_MS=60000

# DeepSeek API Key（用于 AI 解析发布信息）
DEEPSEEK_API_KEY=你的DeepSeek_API_Key

# DeepSeek API Base URL
DEEPSEEK_API_BASE=https://api.deepseek.com

# 微信小程序 AppID
WX_APPID=你的小程序AppID

# 微信小程序 AppSecret
WX_APPSECRET=你的小程序AppSecret
