{
  "easycom": {
    "autoscan": true,
    "custom": {
      "^u-(.*)": "@/components/$1.vue"
    }
  },
  "pages": [
    {
      "path": "pages/index/index",
      "style": {
        "navigationBarTitleText": "再塑通",
        "navigationBarBackgroundColor": "#07C160",
        "navigationBarTextStyle": "white",
        "enablePullDownRefresh": false
      }
    },
    {
      "path": "pages/match/match",
      "style": {
        "navigationBarTitleText": "匹配中心",
        "navigationBarBackgroundColor": "#07C160",
        "navigationBarTextStyle": "white",
        "enablePullDownRefresh": true
      }
    },
    {
      "path": "pages/messages/messages",
      "style": {
        "navigationBarTitleText": "消息中心",
        "navigationBarBackgroundColor": "#07C160",
        "navigationBarTextStyle": "white",
        "enablePullDownRefresh": false
      }
    },
    {
      "path": "pages/market/index",
      "style": {
        "navigationBarTitleText": "行情价格",
        "navigationBarBackgroundColor": "#07C160",
        "navigationBarTextStyle": "white",
        "enablePullDownRefresh": true
      }
    },
    {
      "path": "pages/mine/mine",
      "style": {
        "navigationBarTitleText": "我的",
        "navigationBarBackgroundColor": "#07C160",
        "navigationBarTextStyle": "white",
        "enablePullDownRefresh": true
      }
    }
  ],
  "globalStyle": {
    "navigationBarTextStyle": "white",
    "navigationBarTitleText": "再塑通",
    "navigationBarBackgroundColor": "#07C160",
    "backgroundColor": "#F5F5F5",
    "backgroundTextStyle": "dark"
  },
  "tabBar": {
    "color": "#999999",
    "selectedColor": "#07C160",
    "backgroundColor": "#FFFFFF",
    "borderStyle": "black",
    "list": [
      {
        "pagePath": "pages/index/index",
        "iconPath": "static/tab-home.png",
        "selectedIconPath": "static/tab-home-active.png",
        "text": "首页"
      },
      {
        "pagePath": "pages/match/match",
        "iconPath": "static/tab-match.png",
        "selectedIconPath": "static/tab-match-active.png",
        "text": "匹配"
      },
      {
        "pagePath": "pages/market/index",
        "iconPath": "static/tab-market.png",
        "selectedIconPath": "static/tab-market-active.png",
        "text": "行情"
      },
      {
        "pagePath": "pages/messages/messages",
        "iconPath": "static/tab-message.png",
        "selectedIconPath": "static/tab-message-active.png",
        "text": "消息"
      },
      {
        "pagePath": "pages/mine/mine",
        "iconPath": "static/tab-mine.png",
        "selectedIconPath": "static/tab-mine-active.png",
        "text": "我的"
      }
    ]
  }
}
